PORT=3002
DEFAULT_MODEL=gpt-5.5
OPENAI_API_KEY=your_openai_api_key_here
USE_WEB_INTERFACE=false
USE_CLI=true
CONTEXT_EXPIRE_TIME=3600000
# 子进程超时时间（毫秒），默认10分钟
PROCESS_TIMEOUT=600000
# SSE 心跳间隔（毫秒），用于避免代理或客户端关闭空闲连接
SSE_HEARTBEAT_INTERVAL=15000
# 沙箱模式: read-only | workspace-write | danger-full-access
CODEX_SANDBOX=workspace-write
# Codex 的工作目录（要修改的项目路径），留空则使用代理进程的当前目录
CODEX_WORKDIR=
# 同时运行的 Codex 子进程上限，超出的请求排队等待
MAX_CONCURRENT_REQUESTS=3
# 审批策略: auto（危险操作自动拒绝）| never（全部自动通过）
APPROVAL_POLICY=auto
# 调试模式：启用详细日志输出
DEBUG=false
